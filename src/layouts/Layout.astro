---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Transit maps, infra updates, and charts, hand-drawn and hand-coded.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#10233f" />
    <meta name="description" content={description} />
    <title>{title} · Manchitra Transit Maps</title>
  </head>
  <body>
    <slot />
    <footer class="site-footer">
      <div class="wrap">
        <span>MANCHITRA TRANSIT MAPS — EST. 2026</span>
        <span>ALL LINES OPERATIONAL</span>
      </div>
    </footer>
  </body>
</html>
