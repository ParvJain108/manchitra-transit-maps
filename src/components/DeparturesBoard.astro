---
import type { CollectionEntry } from 'astro:content';
import { CATEGORIES } from '../lib/categories';

interface Props {
  posts: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props;
const base = import.meta.env.BASE_URL;

const sorted = [...posts].sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<div class="board" role="table" aria-label="Post schedule">
  <div class="board-head" role="row">
    <span role="columnheader">Line</span>
    <span role="columnheader">Title</span>
    <span role="columnheader">Posted</span>
  </div>
  {sorted.length === 0 && <p class="empty">No posts on this line yet — check back soon.</p>}
  {sorted.map((post) => {
    const meta = CATEGORIES[post.data.category];
    return (
      <a class="board-row" role="row" href={`${base}blog/${post.data.category}/${post.id}/`}>
        <span role="cell" class={`badge ${meta.badgeClass}`}>{meta.code}</span>
        <span role="cell" class="row-title">{post.data.title}</span>
        <span role="cell" class="row-date">
          {post.data.pubDate.toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' })}
        </span>
      </a>
    );
  })}
</div>

<style>
  .board {
    border-top: 1px solid var(--grid-line);
  }

  .board-head {
    display: grid;
    grid-template-columns: 60px 1fr 130px;
    gap: 16px;
    padding: 10px 16px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--paper-dim);
  }

  .board-row {
    display: grid;
    grid-template-columns: 60px 1fr 130px;
    align-items: center;
    gap: 16px;
    padding: 16px;
    text-decoration: none;
    color: var(--paper);
    border-top: 1px solid var(--grid-line);
    transition: background-color 0.15s ease;
  }

  .board-row:hover {
    background-color: rgba(237, 231, 217, 0.05);
  }

  .row-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.02rem;
  }

  .row-date {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--paper-dim);
    text-align: right;
  }

  .empty {
    padding: 24px 16px;
    color: var(--paper-dim);
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }

  @media (max-width: 560px) {
    .board-head { display: none; }
    .board-row {
      grid-template-columns: 44px 1fr;
      grid-template-areas: "badge title" "empty date";
    }
    .board-row .badge { grid-area: badge; }
    .board-row .row-title { grid-area: title; }
    .board-row .row-date { grid-area: date; text-align: left; }
  }
</style>
