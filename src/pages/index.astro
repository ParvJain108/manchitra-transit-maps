---
import Layout from '../layouts/Layout.astro';
import DeparturesBoard from '../components/DeparturesBoard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
---

<Layout title="Home">
  <header class="hero">
    <div class="wrap">
      <p class="eyebrow">मानचित्र · maps, charts &amp; family lines</p>
      <h1>Manchitra Transit Maps</h1>
      <p class="tagline">
        Transit diagrams, infrastructure updates, charts, and family trees —
        drawn the way a route map is drawn: precisely, and to scale.
      </p>
    </div>
  </header>

  <main class="wrap">
    <h2 class="section-title">Recent departures</h2>
    <DeparturesBoard posts={allPosts} />
  </main>
</Layout>

<style>
  .hero {
    padding: 96px 0 32px;
  }

  h1 {
    font-size: clamp(2.2rem, 6vw, 3.4rem);
    margin: 8px 0 16px;
  }

  .tagline {
    max-width: 56ch;
    color: var(--paper-dim);
    font-size: 1.08rem;
    margin: 0;
  }

  .section-title {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--paper-dim);
    font-weight: 500;
    margin: 48px 0 0;
  }
</style>
